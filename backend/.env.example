# ── MySQL (local) ──────────────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=fintrack

# ── MongoDB (optional) ─────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/fintrack

# ── Neo4j (optional) ───────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── ML API ─────────────────────────────────────────────────
ML_API_URL=http://localhost:8000

# ── Server ─────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Azure (Phase 7 – fill when deploying) ──────────────────
# DB_HOST=your-azure-sql-server.database.windows.net
# DB_USER=your_azure_db_user
# DB_PASSWORD=your_azure_db_password
# DB_NAME=fintrack
# MONGO_URI=mongodb+srv://...
# ML_API_URL=https://your-azure-ml-endpoint.azurewebsites.net
